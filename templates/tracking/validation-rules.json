{
  "version": "1.0",
  "description": "소설 콘텐츠 검증 규칙, 캐릭터 일관성 및 콘텐츠 품질 검사용",

  "characters": {
    "protagonist": {
      "name": "[주인공 이름]",
      "aliases": ["[별명]", "[다른 이름]"],
      "forbidden": ["주인공", "남주", "여주", "[흔한 오류명]"],
      "traits": ["[핵심 정체성]", "[핵심 특징]"],
      "note": "실제 스토리 설정에 맞게 구체적인 내용을 입력하세요"
    },
    "supporting": {
      "[조연1 이름]": {
        "aliases": ["[별명]"],
        "addresses_to": {
          "protagonist": ["[주인공에 대한 호칭]"]
        }
      },
      "[조연2 이름]": {
        "aliases": ["[별명]"],
        "addresses_to": {
          "protagonist": ["[주인공에 대한 호칭]"]
        }
      }
    }
  },

  "relationships": {
    "fixed_addresses": {
      "description": "고정된 인물 간 호칭 관계",
      "rules": {
        "[캐릭터A]→[캐릭터B]": ["[고정 호칭1]", "[고정 호칭2]"],
        "[캐릭터C]→[캐릭터D]": ["[고정 호칭]"]
      }
    },
    "forbidden_addresses": {
      "description": "사용 금지 호칭",
      "rules": {
        "[아랫사람]→[윗사람]": ["[부적절한 호칭]"],
        "[낯선 사람]→[주인공]": ["[지나치게 친밀한 호칭]"]
      }
    }
  },

  "validation_tasks": {
    "character_consistency": {
      "enabled": true,
      "checks": [
        "name_consistency",
        "trait_consistency",
        "behavior_consistency"
      ]
    },
    "relationship_validation": {
      "enabled": true,
      "checks": [
        "address_accuracy",
        "relationship_development",
        "interaction_logic"
      ]
    },
    "world_rules": {
      "enabled": true,
      "checks": [
        "power_system",
        "geography",
        "timeline"
      ]
    }
  },

  "auto_fix": {
    "character_names": {
      "enabled": true,
      "confidence_threshold": 0.9,
      "description": "명백한 캐릭터 이름 오류 자동 수정"
    },
    "addresses": {
      "enabled": true,
      "confidence_threshold": 0.85,
      "description": "고정 호칭 오류 자동 수정"
    },
    "simple_typos": {
      "enabled": true,
      "description": "간단한 오탈자 수정"
    },
    "complex_issues": {
      "enabled": false,
      "description": "복잡한 문제는 제안만 제공하며 자동 수정하지 않음"
    }
  },

  "common_errors": {
    "character_substitution": [
      {"wrong": "[오류 이름1]", "correct": "[올바른 주인공 이름]", "context": "흔한 주인공 이름 오류"},
      {"wrong": "[오류 이름2]", "correct": "[올바른 주인공 이름]", "context": "또 다른 흔한 오류"}
    ],
    "address_mistakes": [
      {"wrong": "[오류 호칭1]", "correct": "[올바른 호칭]", "context": "특정 인물의 주인공에 대한 호칭"},
      {"wrong": "[오류 호칭2]", "correct": "[올바른 호칭]", "context": "웃어른의 주인공에 대한 호칭"}
    ]
  },

  "validation_levels": {
    "quick": {
      "description": "빠른 검증 (집필 시 사용)",
      "checks": ["character_names", "basic_addresses"],
      "time_estimate": "수 초"
    },
    "standard": {
      "description": "표준 검증 (일일 점검)",
      "checks": ["character_consistency", "relationship_validation"],
      "time_estimate": "1-2분"
    },
    "deep": {
      "description": "심층 검증 (출간 전 사용)",
      "checks": ["all"],
      "time_estimate": "5-10분"
    }
  },

  "usage_guide": {
    "write_command": "/write 시 quick 레벨 검증 자동 로드",
    "track_command": "/track --check 로 standard 레벨 검증 실행",
    "fix_command": "/track --fix 로 simple 레벨 문제 자동 수정"
  }
}
